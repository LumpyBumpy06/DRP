# =========================
# APP
# =========================
DATABASE_TYPE=sqlite  # sqlite | postgres

# =========================
# DATABASE CONFIG
# =========================

# Local SQLite fallback (used when APP_ENV=local and no Postgres provided)
SQLITE_FILE=dev.db

# Postgres (used in local docker or kubernetes)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432