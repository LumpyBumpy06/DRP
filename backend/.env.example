# =========================
# QuietSignal Backend Config
# =========================

# Database connection string
# Local dev example:
# DATABASE_URL=sqlite:///./dev.db
#
# Kubernetes (CNPG) example:
# DATABASE_URL=postgresql+psycopg://quietsignal:change-me@quiet-signal-postgres-rw.quiet-signal.svc.cluster.local:5432/quiet-signal

DATABASE_URL=postgresql+psycopg://quietsignal:change-me@quiet-signal-postgres-rw.quiet-signal.svc.cluster.local:5432/quiet-signal

# Enable SQL query logging (useful for debugging)
DATABASE_ECHO=false